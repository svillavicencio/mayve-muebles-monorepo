---
import { fetchSiteConfig } from '../lib/api-client';
import type { SiteConfig } from '../lib/api-client';

let config: SiteConfig | null = null;
try {
  config = await fetchSiteConfig<SiteConfig>();
} catch {
  // fallback: show static content when config is unavailable
}

const address = config?.address || '';
const googleMapsUrl = config?.googleMapsUrl || '';
const whatsapp = config?.whatsapp || '';
const whatsappUrl = whatsapp ? `https://wa.me/${whatsapp}` : '';
const instagramUrl = config?.instagramUrl || '';
---

<section class="section-block bg-primary text-on-primary">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-16 lg:gap-24">
      <div class="space-y-8">
        <h3 class="text-2xl md:text-3xl font-serif tracking-tight">Ubicación</h3>
        {address && (
          <p class="text-base md:text-xl opacity-80 leading-relaxed max-w-[300px]" set:html={address.replace(',', ',<br/>')} />
        )}
        {googleMapsUrl && (
          <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer" class="footer-contact-link border-on-primary">
            Cómo llegar
          </a>
        )}
      </div>

      <div class="space-y-8">
        <h3 class="text-2xl md:text-3xl font-serif tracking-tight">Entregas</h3>
        <ul class="text-base md:text-xl opacity-80 space-y-4">
          <li>Zona Sur</li>
          <li>Zona Oeste</li>
          <li>CABA</li>
        </ul>
      </div>

      <div class="space-y-8">
        <h3 class="text-2xl md:text-3xl font-serif tracking-tight">Contacto</h3>
        <ul class="text-base md:text-xl opacity-80 space-y-4">
          {whatsappUrl && (
            <li>
              <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="hover:text-surface-variant transition-colors">
                WhatsApp
              </a>
            </li>
          )}
          {instagramUrl && (
            <li>
              <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-surface-variant transition-colors">
                Instagram
              </a>
            </li>
          )}
        </ul>
      </div>
    </div>
  </div>
</section>
