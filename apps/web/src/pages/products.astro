---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ProductCatalog } from '../components/ProductCatalog';
---

<Layout title="Colecciones">
	<Header />
	<main class="container">
		<div class="py-12 md:py-16 lg:py-24 max-w-content-medium">
			<h1 class="text-4xl md:text-6xl lg:text-7xl font-serif text-primary mb-6 tracking-tighter italic">Colecciones</h1>
			<p class="label-caps text-secondary opacity-60">
        Una selección rigurosa de piezas icónicas y diseño contemporáneo.
      </p>
		</div>
		
		<ProductCatalog client:load />
	</main>
	<Footer />
</Layout>
