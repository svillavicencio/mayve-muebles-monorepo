---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { fetchProducts, fetchCategories } from '../../lib/api-client';

// Fetching basic stats server-side
let totalProducts = 0;
let totalCategories = 0;

try {
  const products = await fetchProducts<any[]>();
  const categories = await fetchCategories<any[]>();
  totalProducts = products.length;
  totalCategories = categories.length;
} catch (e) {
  console.error('Error fetching admin stats:', e);
}

const stats = [
  {
    label: 'Productos Totales',
    value: totalProducts,
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4'
  },
  {
    label: 'Categorías',
    value: totalCategories,
    icon: 'M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z'
  },
  {
    label: 'Configuración',
    value: 'OK',
    icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z'
  },
];
---

<AdminLayout title="Panel de Administración" isFluid={true}>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
    {stats.map(stat => (
      <div class="bg-white admin-card-p rounded-xl shadow-ambient flex items-center gap-6 hover:-translate-y-1 transition-transform">
        <span class="text-secondary shrink-0">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={stat.icon}></path>
          </svg>
        </span>
        <div>
          <h3 class="text-xs uppercase tracking-widest text-on-surface/60 mb-1">{stat.label}</h3>
          <p class="text-4xl font-bold text-primary font-sans leading-none">{stat.value}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="bg-white admin-card-p rounded-xl border border-surface-variant/30 shadow-ambient">
    <h2 class="text-2xl font-display mb-8">Acciones Rápidas</h2>
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/admin/products/new" class="btn-primary px-8 py-4 font-semibold w-full sm:w-auto">Nuevo Producto</a>
      <a href="/admin/categories" class="btn-primary px-8 py-4 font-semibold w-full sm:w-auto">Gestionar Categorías</a>
      <a href="/admin/config" class="btn-primary px-8 py-4 font-semibold w-full sm:w-auto">Ajustes Globales</a>
    </div>
  </div>
</AdminLayout>
