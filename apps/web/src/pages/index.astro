---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ArtisanSection from '../components/ArtisanSection.astro';
import LocationSection from '../components/LocationSection.astro';
import { FeaturedProductGrid } from '../components/FeaturedProductGrid';
---

<Layout title="Showroom de Diseño">
	<Header />
	<main>
		<Hero />
		
		<section class="section-block">
			<div class="container">
				<FeaturedProductGrid client:load limit={6} title="Piezas Destacadas" />
				<div class="mt-16 text-center">
					<a href="/products" class="inline-block label-caps tracking-label-wide border-b border-primary pb-2 hover:opacity-60 transition-opacity">
						Ver catálogo completo
					</a>
				</div>
			</div>
		</section>

		<ArtisanSection />
		<LocationSection />
	</main>
	<Footer />
</Layout>
