---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { fetchSiteConfig } from '../lib/api-client';
import type { SiteConfig } from '../lib/api-client';

let config: SiteConfig | null = null;
try {
  config = await fetchSiteConfig<SiteConfig>();
} catch {
  // fallback: sections with missing config will be hidden
}

const whatsapp = config?.whatsapp || '';
const whatsappUrl = whatsapp ? `https://wa.me/${whatsapp}` : '';
const address = config?.address || '';
const googleMapsUrl = config?.googleMapsUrl || '';
---

<Layout title="Contacto" description="Consultá a Vero por WhatsApp. Asesoramiento personalizado, sin intermediarios. Entregamos con cuidado en CABA y GBA.">
  <Header />
  <main>

    <!-- Hero -->
    <section class="section-block pt-24 md:pt-32 lg:pt-40">
      <div class="container max-w-content-wide">
        <span class="inline-block label-caps tracking-label-widest text-primary/60 mb-8">
          Contacto
        </span>
        <h1 class="text-4xl md:text-7xl lg:text-[8rem] font-serif leading-tight mb-12 text-primary tracking-tighter">
          Hablemos<br/>de tu espacio.
        </h1>
        <p class="text-xl md:text-2xl text-secondary leading-relaxed max-w-content-narrow opacity-80">
          El asesoramiento es gratis. Contale a Vero cómo es tu ambiente y en qué colores lo imaginás.
        </p>
      </div>
    </section>

    <!-- Contact cards -->
    <section class="section-block bg-primary text-on-primary">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-16 lg:gap-24">

          {whatsappUrl && (
            <div class="space-y-8">
              <h3 class="text-2xl md:text-3xl font-serif tracking-tight">WhatsApp</h3>
              <p class="text-base md:text-xl opacity-80 leading-relaxed">
                La forma más rápida de hablar con Vero. Consultás, elegís colores y coordinamos la entrega.
              </p>
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-contact-link border-on-primary"
              >
                Escribinos por WhatsApp
              </a>
            </div>
          )}

          {address && (
            <div class="space-y-8">
              <h3 class="text-2xl md:text-3xl font-serif tracking-tight">Ubicación</h3>
              <p class="text-base md:text-xl opacity-80 leading-relaxed" set:html={address.replace(',', ',<br/>')} />
              {googleMapsUrl && (
                <a
                  href={googleMapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="footer-contact-link border-on-primary"
                >
                  Cómo llegar
                </a>
              )}
            </div>
          )}

          <div class="space-y-8">
            <h3 class="text-2xl md:text-3xl font-serif tracking-tight">Entregas</h3>
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <span class="mt-1 opacity-70">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </span>
                <div>
                  <p class="text-lg font-bold">Cuidado Artesanal</p>
                  <p class="text-base opacity-70 leading-snug">Tratamos tu mueble como la pieza única que es.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="mt-1 opacity-70">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                </span>
                <div>
                  <p class="text-lg font-bold">Coordinación Directa</p>
                  <p class="text-base opacity-70 leading-snug">Hablás con Vero por WhatsApp para coordinar día y horario.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="mt-1 opacity-70">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </span>
                <div>
                  <p class="text-lg font-bold">Zonas de Entrega</p>
                  <p class="text-base opacity-70 leading-snug">Personalizadas y seguras en Zona Sur, Zona Oeste y CABA.</p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Social proof -->
    <section class="section-block">
      <div class="container text-center space-y-6">
        <p class="text-5xl md:text-7xl font-serif text-primary tracking-tighter">4.9 / 5</p>
        <p class="label-caps tracking-label-widest text-primary/60">más de 200 hogares</p>
        <p class="text-xl text-secondary opacity-70 max-w-content-narrow mx-auto leading-relaxed">
          Calidad, asesoramiento en color y entregas coordinadas. La experiencia que describís vos cuando recomendás Mayve.
        </p>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
